		{
			"name": "Private Cloud Utils",
			"item": [
				{
					"name": "Get DCR Allowed Redirect URIs",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.collectionVariables.set('REDIRECT_URIS', null);",
									"",
									"if (!pm.collectionVariables.get('PRIVATE_CLOUD_TOKEN')) {",
									"    console.warn(`PRIVATE_CLOUD_TOKEN not set, skipping request (${pm.execution.location})`);",
									"    pm.execution.skipRequest();",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code == 200) {",
									"    pm.test(\"Store redirect URIs in collection variable\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData.value).to.not.empty;",
									"        pm.collectionVariables.set('REDIRECT_URIS', jsonData.value);",
									"    });",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{PRIVATE_CLOUD_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "https://{{PRIVATE_CLOUD_URL}}/config/v1/admin/namespaces/{{PRIVATE_PUBLISHER_NAMESPACE}}/configs/dcrAllowedRedirectUris",
							"protocol": "https",
							"host": [
								"{{PRIVATE_CLOUD_URL}}"
							],
							"path": [
								"config",
								"v1",
								"admin",
								"namespaces",
								"{{PRIVATE_PUBLISHER_NAMESPACE}}",
								"configs",
								"dcrAllowedRedirectUris"
							]
						}
					},
					"response": []
